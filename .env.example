# Runtime
BFF_ENV=development

# Frontend / browser session
FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# MCP server
MCP_URL=https://github-unified-mcp.onrender.com
MCP_TOKEN=your_mcp_bearer_token_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
PORT=8000

# GitHub OAuth (Camada 2 — crie um OAuth App em github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/auth/callback

# JWT
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=3600

# RBAC — GitHub usernames com acesso elevado (vírgula-separados)
RBAC_OPERATOR_USERS=
RBAC_ADMIN_USERS=

# Audit log
AUDIT_DB_PATH=audit.db
AUDIT_RETENTION_DAYS=90
